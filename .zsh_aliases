# Git
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gpl='git pull'
alias gd='git diff'
alias gl='git log'
alias gb='git branch'
alias gco='git checkout'
alias gr='git remote -v'

# Docker
alias dps='docker ps'
alias dex='docker exec -it'
alias drm='docker rm'
alias dimg='docker images'

# ls
alias ll='ls -al'
alias la='ls -A'
alias l='ls -CF'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'

# Editor
alias v='nvim'

alias icloud='cd ~/Library/Mobile\ Documents/com~apple~CloudDocs'

# universal-ctags（Homebrew keg-only，不会自动 shadow 系统 ctags）
alias ctags="$(brew --prefix universal-ctags 2>/dev/null)/bin/ctags"
