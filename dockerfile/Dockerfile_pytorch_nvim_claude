# ==============================================================================
# smart_nvim + Claude Code 开发镜像
# Base: NVIDIA PyTorch（含 CUDA、cuDNN、Python）
#
# 完全自包含构建，不依赖宿主机 nvim 状态，仅依赖 smart_dotfiles 目录。
#
# 构建（不带代理）：
#   docker build --platform=linux/amd64 --network host \
#     -f dockerfile/Dockerfile_pytorch_nvim_claude .
#
# 构建（带代理 + Claude 配置）：
#   docker build --platform=linux/amd64 --network host \
#     --build-arg PROXY_IP=192.168.31.19 \
#     --build-arg PROXY_PORT=8118 \
#     --build-arg ANTHROPIC_AUTH_TOKEN=your_token \
#     -f dockerfile/Dockerfile_pytorch_nvim_claude .
# ==============================================================================

FROM nvcr.io/nvidia/pytorch:25.12-py3

# 代理和认证配置（可选，构建时通过 --build-arg 传入）
ARG PROXY_IP
ARG PROXY_PORT
ARG ANTHROPIC_AUTH_TOKEN

# 如果设置了代理，配置 apt（apt 不读 env var）
RUN if [ -n "$PROXY_IP" ]; then \
      echo "Acquire::http::Proxy \"http://${PROXY_IP}:${PROXY_PORT}\";" > /etc/apt/apt.conf.d/99proxy; \
      echo "Acquire::https::Proxy \"http://${PROXY_IP}:${PROXY_PORT}\";" >> /etc/apt/apt.conf.d/99proxy; \
    fi

# 设置全局代理 env（build 阶段供 curl/wget/git/npm 使用，runtime 也生效）
ENV http_proxy=http://${PROXY_IP}:${PROXY_PORT} \
    https_proxy=http://${PROXY_IP}:${PROXY_PORT}

# 切换 apt 源到国内镜像（163）
RUN sed -i s/archive.ubuntu.com/mirrors.163.com/g /etc/apt/sources.list && \
    sed -i s/security.ubuntu.com/mirrors.163.com/g /etc/apt/sources.list

# 安装系统依赖（update 与 install 必须在同一 RUN，避免 Docker 缓存导致 stale index）
#   - wget git ca-certificates build-essential: 基础构建工具
#   - ripgrep fd-find: telescope live_grep / find_files 后端
#   - universal-ctags: <C-]> 跳转定义（ctags + telescope 方案，替代 clangd）
#   - xclip: nvim 系统剪贴板支持
RUN apt-get update && apt-get install -y --no-install-recommends \
      wget \
      git \
      ca-certificates \
      build-essential \
      ripgrep \
      fd-find \
      universal-ctags \
      xclip \
      tmux \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# fd-find 在 Ubuntu 上的二进制名为 fdfind，telescope 默认查找 fd
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd

# 安装 Node.js 20（claude-code 依赖，nodesource 自带 npm，无需单独安装）
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# 安装 nvim v0.11.6
RUN wget --no-check-certificate \
      https://github.com/neovim/neovim/releases/download/v0.11.6/nvim-linux-x86_64.tar.gz \
    && tar -zxf nvim-linux-x86_64.tar.gz \
    && cp -r nvim-linux-x86_64/* /usr/local/ \
    && rm -rf nvim-linux-x86_64 nvim-linux-x86_64.tar.gz

# 从 smart_dotfiles 安装（COPY 仅依赖本地目录，无需 git clone）
COPY .config/nvim /root/.config/nvim
COPY .config/tmux /root/.config/tmux
COPY .zsh_aliases /root/.zsh_aliases
COPY .ctags.d /root/.ctags.d

# 生成 .zsh_env（替换占位符为实际值）
COPY .zsh_env /tmp/.zsh_env.tpl
RUN sed -e "s#{{PROXY_IP}}#${PROXY_IP}#g" \
        -e "s#{{PROXY_PORT}}#${PROXY_PORT}#g" \
        -e "s#{{AUTH_TOKEN}}#${ANTHROPIC_AUTH_TOKEN}#g" \
        /tmp/.zsh_env.tpl > /root/.zsh_env && \
    rm /tmp/.zsh_env.tpl

# 容器默认 shell 是 bash，source aliases 和 env
RUN echo "source ~/.zsh_aliases" >> ~/.bashrc && \
    echo "source ~/.zsh_env" >> ~/.bashrc

# 安装 nvim 插件（headless 模式，lazy-lock.json 锁定版本）
#   - :Lazy! sync 安装/更新所有 lazy.nvim 插件
#   - nvim-treesitter 的 build hook 会自动编译 treesitter parser
#   - || true 是因为 nvim headless 可能因 UI 相关 warning 返回非零退出码
RUN nvim --headless "+Lazy! sync" +qa || true

# 安装 Claude Code（使用 npmmirror 国内源）
RUN npm install -g @anthropic-ai/claude-code --registry=https://registry.npmmirror.com
